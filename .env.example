# ==========================================
# 项目环境变量配置示例
# 使用方法：复制此文件为 .env 并修改对应值
# ==========================================

# ---------- 基础配置 ----------
TZ=Asia/Shanghai
LANG=C.UTF-8

# ---------- Spring Profile ----------
# dev | test | prod
SPRING_PROFILES_ACTIVE=dev

# ---------- 数据库配置 ----------
MYSQL_ROOT_PASSWORD=your_secure_root_password
MYSQL_DATABASE=mybatis_demo
MYSQL_USER=mybatis_user
MYSQL_PASSWORD=your_secure_db_password

# 数据库连接池配置
DB_PORT=33959
DB_MAX_POOL_SIZE=20
DB_MIN_IDLE=10
DB_CONNECTION_TIMEOUT=30000
DB_INIT_TIMEOUT=120000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# Spring 数据源配置（从环境变量读取）
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/mybatis_demo?useUnicode=true&characterEncoding=UTF-8&connectionCollation=utf8mb4_unicode_ci&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_secure_root_password

# ---------- JWT 配置 ----------
# 生产环境必须修改为强密钥（至少 256 位，推荐使用 openssl rand -hex 32 生成）
JWT_SECRET=your_very_long_secure_secret_key_here_at_least_32_bytes_please_change_this
JWT_EXPIRE_HOURS=24
JWT_ISSUER=mybatis-plus-demo

# ---------- 服务端口配置 ----------
FRONTEND_PORT=3959
BACKEND_PORT=8959
BACKEND_MGMT_PORT=9959

# ---------- 日志级别 ----------
# trace | debug | info | warn | error
LOG_LEVEL_APP=info
LOG_LEVEL_MP=warn
LOG_LEVEL_SECURITY=warn

# ---------- Actuator 配置 ----------
# 暴露的端点（逗号分隔）
ACTUATOR_ENDPOINTS=health,info,metrics,prometheus
# never | when-authorized | always
ACTUATOR_HEALTH_DETAILS=never

# ---------- JVM 参数 ----------
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC -XX:MaxGCPauseMillis=100 -Djava.security.egd=file:/dev/./urandom

# ---------- Docker 构建参数 ----------
BUILD_PROFILE=prod
SKIP_TESTS=true
FRONTEND_BUILD_MODE=production

# ---------- 测试环境专用 ----------
TEST_DB_URL=jdbc:mysql://localhost:3306/mybatis_demo_test?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
TEST_DB_USERNAME=root
TEST_DB_PASSWORD=your_test_db_password
TEST_JWT_SECRET=test_secret_key_for_unit_tests_only_0987654321
