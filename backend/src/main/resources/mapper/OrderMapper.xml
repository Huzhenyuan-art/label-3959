<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.OrderMapper">

    <!-- 订单列表结果映射 -->
    <resultMap id="OrderDetailMap" type="com.example.demo.dto.OrderDetailDTO">
        <id property="id" column="order_id"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="userEmail" column="user_email"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="status" column="status"/>
        <result property="statusLabel" column="status_label"/>
        <result property="remark" column="remark"/>
        <result property="version" column="version"/>
        <result property="createdTime" column="created_time"/>
        <result property="updatedTime" column="updated_time"/>
    </resultMap>

    <!-- 含明细的订单详情结果映射 -->
    <resultMap id="OrderDetailWithItemsMap" type="com.example.demo.dto.OrderDetailDTO">
        <id property="id" column="order_id"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="userEmail" column="user_email"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="status" column="status"/>
        <result property="statusLabel" column="status_label"/>
        <result property="remark" column="remark"/>
        <result property="version" column="version"/>
        <result property="createdTime" column="created_time"/>
        <result property="updatedTime" column="updated_time"/>
        <!-- 一对多：订单明细 -->
        <collection property="items" ofType="com.example.demo.dto.OrderDetailDTO$OrderItemDTO">
            <id property="id" column="item_id"/>
            <result property="productId" column="product_id"/>
            <result property="productName" column="product_name"/>
            <result property="productCategory" column="product_category"/>
            <result property="quantity" column="quantity"/>
            <result property="price" column="item_price"/>
            <result property="subtotal" column="subtotal"/>
        </collection>
    </resultMap>

    <!--
        分页查询订单（联查用户信息）
        演示：多表 JOIN + 动态条件 + MyBatis Plus 分页插件自动处理 count 和 limit
    -->
    <select id="selectOrderPage" resultMap="OrderDetailMap">
        SELECT
            o.id         AS order_id,
            o.user_id,
            u.username,
            u.email      AS user_email,
            o.total_amount,
            o.status,
            CASE o.status
                WHEN 0 THEN '待支付'
                WHEN 1 THEN '已支付'
                WHEN 2 THEN '已发货'
                WHEN 3 THEN '已完成'
                WHEN 4 THEN '已取消'
            END          AS status_label,
            o.remark,
            o.version,
            o.created_time,
            o.updated_time
        FROM `order` o
        LEFT JOIN user u ON o.user_id = u.id AND u.deleted = 0
        <where>
            <if test="username != null and username != ''">
                AND u.username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="status != null">
                AND o.status = #{status}
            </if>
            <if test="userId != null">
                AND o.user_id = #{userId}
            </if>
        </where>
        ORDER BY o.created_time DESC
    </select>

    <!--
        查询订单详情（联查用户 + 一对多明细 + 商品信息）
        演示：多表 JOIN 一对多映射
    -->
    <select id="selectOrderDetail" resultMap="OrderDetailWithItemsMap">
        SELECT
            o.id            AS order_id,
            o.user_id,
            u.username,
            u.email         AS user_email,
            o.total_amount,
            o.status,
            CASE o.status
                WHEN 0 THEN '待支付'
                WHEN 1 THEN '已支付'
                WHEN 2 THEN '已发货'
                WHEN 3 THEN '已完成'
                WHEN 4 THEN '已取消'
            END             AS status_label,
            o.remark,
            o.version,
            o.created_time,
            o.updated_time,
            oi.id           AS item_id,
            oi.product_id,
            oi.product_name,
            p.category      AS product_category,
            oi.quantity,
            oi.price        AS item_price,
            (oi.price * oi.quantity) AS subtotal
        FROM `order` o
        LEFT JOIN user u        ON o.user_id    = u.id AND u.deleted = 0
        LEFT JOIN order_item oi ON oi.order_id  = o.id
        LEFT JOIN product p     ON oi.product_id = p.id
        WHERE o.id = #{id}
        ORDER BY oi.id
    </select>

</mapper>
