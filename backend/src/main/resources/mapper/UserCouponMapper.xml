<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.UserCouponMapper">

    <resultMap id="UserCouponDTOMap" type="com.example.demo.dto.UserCouponDTO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="template_id" property="templateId"/>
        <result column="name" property="couponName"/>
        <result column="type" property="couponType"/>
        <result column="discount_amount" property="discountAmount"/>
        <result column="discount_rate" property="discountRate"/>
        <result column="min_amount" property="minAmount"/>
        <result column="coupon_code" property="couponCode"/>
        <result column="status" property="status"/>
        <result column="used_time" property="usedTime"/>
        <result column="order_id" property="orderId"/>
        <result column="valid_start_time" property="validStartTime"/>
        <result column="valid_end_time" property="validEndTime"/>
        <result column="created_time" property="createdTime"/>
    </resultMap>

    <select id="selectUserCouponList" resultMap="UserCouponDTOMap">
        SELECT
            uc.id,
            uc.user_id,
            uc.template_id,
            ct.name,
            ct.type,
            ct.discount_amount,
            ct.discount_rate,
            ct.min_amount,
            uc.coupon_code,
            uc.status,
            uc.used_time,
            uc.order_id,
            uc.valid_start_time,
            uc.valid_end_time,
            uc.created_time
        FROM user_coupon uc
        LEFT JOIN coupon_template ct ON uc.template_id = ct.id
        WHERE uc.user_id = #{userId}
        <if test="status != null">
            AND uc.status = #{status}
        </if>
        ORDER BY uc.created_time DESC
    </select>

    <select id="selectUserCouponDetail" resultMap="UserCouponDTOMap">
        SELECT
            uc.id,
            uc.user_id,
            uc.template_id,
            ct.name,
            ct.type,
            ct.discount_amount,
            ct.discount_rate,
            ct.min_amount,
            uc.coupon_code,
            uc.status,
            uc.used_time,
            uc.order_id,
            uc.valid_start_time,
            uc.valid_end_time,
            uc.created_time
        FROM user_coupon uc
        LEFT JOIN coupon_template ct ON uc.template_id = ct.id
        WHERE uc.id = #{id}
    </select>

</mapper>
